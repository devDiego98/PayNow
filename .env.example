# Loaded by `src/server.ts` and Jest setup via `dotenv` (copy to `.env` for local dev).
# App
NODE_ENV=development
PORT=3000
# Set to 1 to run `npm run start` without ngrok (production / manual tunnel).
SKIP_NGROK=
API_KEY_SECRET=your_secret_for_signing_api_keys

# Database — use port 5433 when Postgres runs via `docker compose -f docker/docker-compose.yml up -d db`
# (avoids connecting to a different server on localhost:5432). User/password/db match the compose file.
DATABASE_URL=postgresql://paygate:paygate@localhost:5433/paygate

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Page Stripe redirects to after payment methods that leave your site (3DS, some wallets).
# Required in some Dashboard/config cases even with card-only flows; use HTTPS in production.
# Example local: http://localhost:3000/payments/return
STRIPE_PAYMENT_RETURN_URL=http://localhost:3000/payments/return

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=TEST-...
# From Mercado Pago → Your integrations → Webhooks (secret signature). When set, POST /api/v1/webhooks/mercadopago must include valid x-signature / x-request-id (see docs).
MERCADOPAGO_WEBHOOK_SECRET=
# Optional: require request body alias / cbu to match (recipient labeling & guardrails). Settlement uses the MP account for MERCADOPAGO_ACCESS_TOKEN.
MERCADOPAGO_RECIPIENT_ALIAS=
MERCADOPAGO_RECIPIENT_CBU=
# Webhook URL for Checkout Pro preferences (must be HTTPS and publicly reachable in production so Mercado Pago can POST).
# Our handler persists payment proof: POST /api/v1/webhooks/mercadopago
MERCADOPAGO_NOTIFICATION_URL=https://example.com/api/v1/webhooks/mercadopago
MERCADOPAGO_BACK_URL_SUCCESS=http://localhost:3000/pay/ok
MERCADOPAGO_BACK_URL_PENDING=http://localhost:3000/pay/pending
MERCADOPAGO_BACK_URL_FAILURE=http://localhost:3000/pay/fail
